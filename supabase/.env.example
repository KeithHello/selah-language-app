# Selah Supabase Environment Variables
# Copy to .env and fill in real values. Do NOT commit the real .env.

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your_secret_key
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_publishable_key

# OpenAI (GPT-4o-mini + TTS tts-1)
OPENAI_API_KEY=sk-your-openai-api-key

# App Config
DEFAULT_VOICE=nova
DEFAULT_SPEED=0.85
